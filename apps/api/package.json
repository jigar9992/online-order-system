{
  "name": "@online-order-system/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "@nestjs/platform-express": "*",
    "@online-order-system/types": "workspace:*",
    "reflect-metadata": "*",
    "rxjs": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "*",
    "@nestjs/testing": "*",
    "@types/node": "*",
    "@types/supertest": "*",
    "supertest": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "scripts": {
    "build": "nest build",
    "dev": "corepack pnpm --filter @online-order-system/types build && nest start --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
